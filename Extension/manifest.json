{
  "manifest_version": 3,
  "name": "VenForce GO",
  "version": "1.1.4",
  "description": "Extensão VenForce GO para cálculo de LC e MC no Mercado Livre e Shopee",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:4127/*",
    "https://www.mercadolivre.com.br/*",
    "https://*.mercadolivre.com.br/*",
    "https://www.mercadolivre.com/*",
    "https://*.mercadolivre.com/*",
    "https://seller.shopee.com.br/*",
    "https://*.seller.shopee.com.br/*",
    "https://shopee.com.br/*",
    "https://*.shopee.com.br/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VenForce GO"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.mercadolivre.com.br/*",
        "https://*.mercadolivre.com.br/*",
        "https://www.mercadolivre.com/*",
        "https://*.mercadolivre.com/*",
        "https://seller.shopee.com.br/*",
        "https://*.seller.shopee.com.br/*",
        "https://shopee.com.br/*",
        "https://*.shopee.com.br/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "custos.json",
        "logo-vendex.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}